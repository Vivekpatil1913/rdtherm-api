// R&D Therm — database schema (MySQL, single-tenant).
// Field names are camelCase (matching the admin panel's TypeScript types) and
// mapped to snake_case columns. IDs are unsigned BIGINT auto-increment.
// Status/group/kind are plain strings validated by the API layer so the JSON
// contract matches the admin exactly (e.g. "in-progress", "published").

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── Auth & system ─────────────────────────

model User {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name         String    @db.VarChar(150)
  email        String    @unique @db.VarChar(190)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         String    @default("admin") @db.VarChar(30)
  avatarUrl    String?   @map("avatar_url") @db.Text
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  refreshTokens  RefreshToken[]
  passwordResets PasswordReset[]
  auditLogs      AuditLog[]

  @@map("users")
}

model RefreshToken {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId        BigInt    @map("user_id") @db.UnsignedBigInt
  tokenHash     String    @unique @map("token_hash") @db.VarChar(255)
  userAgent     String?   @map("user_agent") @db.VarChar(255)
  ip            String?   @db.VarChar(64)
  expiresAt     DateTime  @map("expires_at")
  revokedAt     DateTime? @map("revoked_at")
  replacedBy    String?   @map("replaced_by") @db.VarChar(255)
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  actorId   BigInt?  @map("actor_id") @db.UnsignedBigInt
  actor     String   @db.VarChar(150)
  action    String   @db.VarChar(60)
  target    String   @db.VarChar(255)
  module    String   @db.VarChar(60)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@map("audit_logs")
}

// ───────────────────────── Homepage content ─────────────────────────

model Testimonial {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  author    String   @db.VarChar(150)
  role      String   @db.VarChar(150)
  body      String   @db.Text
  rating    Int      @default(5)
  avatarUrl String?  @map("avatar_url") @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, sortOrder])
  @@index([isDeleted, isActive])
  @@map("testimonials")
}

model Industry {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  key         String   @db.VarChar(120)
  label       String   @db.VarChar(200)
  description String   @db.Text
  coverUrl    String   @map("cover_url") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, sortOrder])
  @@index([key])
  @@map("industries")
}

// ───────────────────────── Products ─────────────────────────

model Product {
  id           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  slug         String   @db.VarChar(190)
  title        String   @db.VarChar(255)
  summary      String   @db.Text
  coverUrl     String   @map("cover_url") @db.Text
  content      String   @db.LongText
  featured     Boolean  @default(false)
  specs        Json?
  applications Json?
  materials    Json?
  compliance   Json?
  benefits     Json?
  inclusions   Json?
  isActive     Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  images ProductImage[]

  @@index([isDeleted, sortOrder])
  @@index([isDeleted, isActive])
  @@index([isDeleted, featured])
  @@index([slug])
  @@map("products")
}

model ProductImage {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  productId BigInt   @map("product_id") @db.UnsignedBigInt
  url       String   @db.Text
  alt       String   @default("") @db.VarChar(255)
  label     String?  @db.VarChar(255)
  sortOrder Int      @default(0) @map("sort_order")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ───────────────────────── Blogs & case studies ─────────────────────────

model BlogPost {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  slug        String    @db.VarChar(190)
  title       String    @db.VarChar(255)
  excerpt     String    @db.Text
  category    String    @db.VarChar(80)
  author      String    @db.VarChar(150)
  coverUrl    String    @map("cover_url") @db.Text
  content     String    @db.LongText
  readTime    String    @default("") @map("read_time") @db.VarChar(40)
  views       Int       @default(0)
  publishedAt DateTime? @map("published_at")
  isActive    Boolean   @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isDeleted, sortOrder])
  @@index([isDeleted, publishedAt])
  @@index([isDeleted, views])
  @@index([isDeleted, category])
  @@index([slug])
  @@map("blog_posts")
}

model CaseStudy {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  slug      String   @db.VarChar(190)
  title     String   @db.VarChar(255)
  client    String   @db.VarChar(190)
  industry  String   @db.VarChar(190)
  summary   String   @db.Text
  coverUrl  String   @map("cover_url") @db.Text
  content   String   @db.LongText
  metrics   Json?
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, sortOrder])
  @@index([slug])
  @@map("case_studies")
}

model Faq {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  question  String   @db.Text
  answer    String   @db.Text
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, sortOrder])
  @@map("faqs")
}

// ───────────────────────── People & brand ─────────────────────────

model TeamMember {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name      String   @db.VarChar(150)
  role      String   @db.VarChar(150)
  bio       String   @db.Text
  photoUrl  String   @map("photo_url") @db.Text
  group     String   @default("team") @db.VarChar(30)
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, sortOrder])
  @@index([isDeleted, group])
  @@map("team_members")
}

model Logo {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name      String   @db.VarChar(190)
  imageUrl  String?  @map("image_url") @db.Text
  href      String?  @db.VarChar(255)
  kind      String   @default("client") @db.VarChar(30)
  isActive  Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, kind, sortOrder])
  @@index([isDeleted, sortOrder])
  @@map("logos")
}

model JobOpening {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  title       String   @db.VarChar(200)
  department  String   @db.VarChar(120)
  location    String   @db.VarChar(150)
  type        String   @db.VarChar(60)
  description String   @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, sortOrder])
  @@index([isDeleted, department])
  @@map("job_openings")
}

// ───────────────────────── Engagement ─────────────────────────

model Lead {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name       String   @db.VarChar(150)
  email      String   @db.VarChar(190)
  phone      String   @default("") @db.VarChar(60)
  company    String   @default("") @db.VarChar(190)
  subject    String   @default("") @db.VarChar(255)
  message    String   @db.Text
  source     String   @default("Contact form") @db.VarChar(120)
  leadStatus String   @default("new") @map("lead_status") @db.VarChar(20)
  feedback   String?  @db.VarChar(255)
  isActive   Boolean  @default(true) @map("is_active")
  isDeleted Boolean  @default(false) @map("is_deleted")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, leadStatus, createdAt])
  @@index([isDeleted, createdAt])
  @@index([isDeleted, sortOrder])
  @@map("leads")
}

model QuoteRequest {
  id            BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name          String   @db.VarChar(150)
  email         String   @db.VarChar(190)
  mobile        String   @db.VarChar(40)
  company       String   @default("") @db.VarChar(190)
  country       String   @default("") @db.VarChar(120)
  city          String   @default("") @db.VarChar(120)
  message       String   @db.Text
  productName   String   @default("Air Receiver") @map("product_name") @db.VarChar(150)
  quoteType     String   @default("standard") @map("quote_type") @db.VarChar(20)
  configuration Json?
  source        String   @default("Website") @db.VarChar(120)
  quoteStatus   String   @default("new") @map("quote_status") @db.VarChar(20)
  isActive      Boolean  @default(true) @map("is_active")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([isDeleted, quoteStatus, createdAt])
  @@index([isDeleted, createdAt])
  @@index([isDeleted, sortOrder])
  @@map("quote_requests")
}

// ───────────────────────── Settings ─────────────────────────

model SiteSetting {
  id          BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  name        String   @db.VarChar(190)
  shortName   String   @map("short_name") @db.VarChar(120)
  parent      String   @db.VarChar(190)
  tagline     String   @db.VarChar(255)
  description String   @db.Text
  address     String   @db.Text
  phone       String   @db.VarChar(60)
  email       String   @db.VarChar(190)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model SocialLink {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  label     String   @db.VarChar(80)
  href      String   @db.VarChar(255)
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("social_links")
}

model BusinessHour {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  label     String   @db.VarChar(80)
  value     String   @db.VarChar(120)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("business_hours")
}
