DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/rdtherm"

PORT=4000
NODE_ENV=production

# Public base URL of THIS api (used to build uploaded-image URLs). No trailing slash.
API_URL=https://rdtherm-api.sumagodemo.com

# Comma-separated list of allowed front-end origins (admin + website).
CORS_ORIGINS=https://rdtherm-admin.sumagodemo.com,https://rdtherm-web.sumagodemo.com

JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_EXPIRES=24h
JWT_REFRESH_EXPIRES=24h

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=1
# Allowed image pixel dimensions (raster formats).
IMAGE_MIN_DIM=100
IMAGE_MAX_DIM=4000

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="R&D Therm CMS <no-reply@rdtherm.com>"

# Admin panel URL (used in password-reset / notification emails).
ADMIN_URL=https://rdtherm-admin.sumagodemo.com

SEED_ADMIN_NAME="Site Admin"
SEED_ADMIN_EMAIL=admin@rdtherm.com
SEED_ADMIN_PASSWORD=Admin@1234
